{
  "version": 2,
  "name": "hospital-management-backend",
  "builds": [
    {
      "src": "dist/app.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/dist/app.js"
    }
  ],
  "buildCommand": "npm run build:backend",
  "installCommand": "npm install",
  "env": {
    "NODE_ENV": "production"
  }
}