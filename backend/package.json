{
  "name": "de-tender-care-backend",
  "version": "1.0.0",
  "description": "De Tender Care Hospital - Patient File Management System Backend",
  "main": "dist/app.js",
  "scripts": {
    "build": "tsc && npm run copy-js",
    "copy-js": "node -e \"const fs=require('fs'),path=require('path');const copyFiles=(src,dest)=>{if(!fs.existsSync(dest))fs.mkdirSync(dest,{recursive:true});fs.readdirSync(src,{withFileTypes:true}).forEach(entry=>{const srcPath=path.join(src,entry.name);const destPath=path.join(dest,entry.name);if(entry.isDirectory())copyFiles(srcPath,destPath);else if(entry.name.endsWith('.js'))fs.copyFileSync(srcPath,destPath);});};['config','middleware','models','routes'].forEach(dir=>{const srcDir=path.join('src',dir);const destDir=path.join('dist',dir);if(fs.existsSync(srcDir))copyFiles(srcDir,destPath);});console.log('JS files copied');\"",
    "start": "node dist/app.js",
    "vercel-build": "npm run build",
    "dev": "ts-node-dev --respawn --transpile-only src/app.ts",
    "dev:watch": "nodemon --exec ts-node src/app.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "db:seed": "ts-node scripts/seed-data.ts",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "bcryptjs": "^3.0.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.1",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.7.0",
    "morgan": "^1.10.0",
    "sqlite3": "^5.1.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.1",
    "@types/compression": "^1.7.4",
    "@types/cors": "^2.8.15",
    "@types/express": "^4.17.20",
    "@types/jest": "^29.5.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.7",
    "@types/node": "^20.8.6",
    "@types/sqlite3": "^3.1.9",
    "@types/supertest": "^2.0.15",
    "@typescript-eslint/eslint-plugin": "^6.9.0",
    "@typescript-eslint/parser": "^6.9.0",
    "eslint": "^8.52.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "rimraf": "^5.0.5",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.2.2"
  },
  "keywords": [
    "hospital",
    "sqlite",
    "patient-management",
    "staff-tracking",
    "typescript",
    "express"
  ],
  "author": "De Tender Care Hospital",
  "license": "ISC"
}