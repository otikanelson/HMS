{
  "version": 2,
  "name": "hospital-management-backend",
  "builds": [
    {
      "src": "src/app.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/src/app.ts"
    }
  ],
  "installCommand": "npm install --legacy-peer-deps",
  "framework": null
}