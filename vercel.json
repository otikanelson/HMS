{
  "version": 2,
  "name": "hospital-management-backend",
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.ts"
    }
  ],
  "installCommand": "npm install --legacy-peer-deps",
  "framework": null,
  "env": {
    "VERCEL": "1"
  }
} 